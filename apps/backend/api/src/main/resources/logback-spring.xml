<configuration>
  <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n"/>
  <property name="HTTP_LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss} %msg%n"/>

  <property name="LOCAL_APP_LOG_DIR" value="logs/app"/>
  <property name="LOCAL_ERROR_LOG_DIR" value="logs/error"/>
  <property name="LOCAL_DB_LOG_DIR" value="logs/db"/>
  <property name="LOCAL_HTTP_LOG_DIR" value="logs/http"/>

  <property name="PROD_APP_LOG_DIR" value="/var/log/feel-archive/app"/>
  <property name="PROD_ERROR_LOG_DIR" value="/var/log/feel-archive/error"/>
  <property name="PROD_HTTP_LOG_DIR" value="/var/log/feel-archive/http"/>

  <springProfile name="local">
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>${LOG_PATTERN}</pattern>
      </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${LOCAL_APP_LOG_DIR}/app.log</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>${LOCAL_APP_LOG_DIR}/app.%d{yyyy-MM-dd}.log</fileNamePattern>
        <maxHistory>3</maxHistory>
        <totalSizeCap>200MB</totalSizeCap>
      </rollingPolicy>
      <encoder><pattern>${LOG_PATTERN}</pattern></encoder>
    </appender>

    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${LOCAL_ERROR_LOG_DIR}/error.log</file>
      <filter class="ch.qos.logback.classic.filter.LevelFilter">
        <level>ERROR</level>
        <onMatch>ACCEPT</onMatch>
        <onMismatch>DENY</onMismatch>
      </filter>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>${LOCAL_ERROR_LOG_DIR}/error.%d{yyyy-MM-dd}.log</fileNamePattern>
        <maxHistory>3</maxHistory>
        <totalSizeCap>300MB</totalSizeCap>
      </rollingPolicy>
      <encoder><pattern>${LOG_PATTERN}</pattern></encoder>
    </appender>

    <appender name="DB_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${LOCAL_DB_LOG_DIR}/db.log</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>${LOCAL_DB_LOG_DIR}/db.%d{yyyy-MM-dd}.log</fileNamePattern>
        <maxHistory>3</maxHistory>
        <totalSizeCap>200MB</totalSizeCap>
      </rollingPolicy>
      <encoder><pattern>${LOG_PATTERN}</pattern></encoder>
    </appender>

    <appender name="HTTP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${LOCAL_HTTP_LOG_DIR}/http.log</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>${LOCAL_HTTP_LOG_DIR}/http.%d{yyyy-MM-dd}.log</fileNamePattern>
        <maxHistory>3</maxHistory>
        <totalSizeCap>500MB</totalSizeCap>
      </rollingPolicy>
      <encoder><pattern>${HTTP_LOG_PATTERN}</pattern></encoder>
    </appender>

    <logger name="p6spy" level="INFO" additivity="false">
      <appender-ref ref="DB_FILE"/>
    </logger>
    <logger name="HTTP_ACCESS" level="INFO" additivity="false">
      <appender-ref ref="HTTP_FILE"/>
    </logger>

    <root level="INFO">
      <appender-ref ref="CONSOLE"/>
      <appender-ref ref="FILE"/>
      <appender-ref ref="ERROR_FILE"/>
    </root>
  </springProfile>

  <springProfile name="prod">
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${PROD_APP_LOG_DIR}/app.log</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>${PROD_APP_LOG_DIR}/app.%d{yyyy-MM-dd}.log</fileNamePattern>
        <maxHistory>30</maxHistory>
        <totalSizeCap>500MB</totalSizeCap>
      </rollingPolicy>
      <encoder><pattern>${LOG_PATTERN}</pattern></encoder>
    </appender>

    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${PROD_ERROR_LOG_DIR}/error.log</file>
      <filter class="ch.qos.logback.classic.filter.LevelFilter">
        <level>ERROR</level>
        <onMatch>ACCEPT</onMatch>
        <onMismatch>DENY</onMismatch>
      </filter>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>${PROD_ERROR_LOG_DIR}/error.%d{yyyy-MM-dd}.log</fileNamePattern>
        <maxHistory>30</maxHistory>
        <totalSizeCap>300MB</totalSizeCap>
      </rollingPolicy>
      <encoder><pattern>${LOG_PATTERN}</pattern></encoder>
    </appender>

    <appender name="HTTP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
      <file>${PROD_HTTP_LOG_DIR}/http.log</file>
      <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
        <fileNamePattern>${PROD_HTTP_LOG_DIR}/http.%d{yyyy-MM-dd}.log</fileNamePattern>
        <maxHistory>30</maxHistory>
        <totalSizeCap>500MB</totalSizeCap>
      </rollingPolicy>
      <encoder><pattern>${HTTP_LOG_PATTERN}</pattern></encoder>
    </appender>

    <logger name="HTTP_ACCESS" level="INFO" additivity="false">
      <appender-ref ref="HTTP_FILE"/>
    </logger>

    <root level="INFO">
      <appender-ref ref="FILE"/>
      <appender-ref ref="ERROR_FILE"/>
    </root>
  </springProfile>
</configuration>
